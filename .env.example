# Copy to .env and fill in. NEVER commit .env.

# Base mainnet RPC (Alchemy / QuickNode / publicnode)
BASE_RPC=https://base-rpc.publicnode.com

# Base Sepolia RPC (only if you want to test on testnet first)
BASE_SEPOLIA_RPC=https://base-sepolia-rpc.publicnode.com

# Basescan v2 API key (auto-verifies the deployed contract)
BASESCAN_KEY=YOUR_BASESCAN_API_KEY

# Uniswap V4 Base mainnet addresses (defaults already baked into Deploy.s.sol — override only for testnets)
# POOL_MANAGER=0x498581fF718922c3f8e6A244956aF099B2652b2b
# POSITION_MANAGER=0x7C5f5A4bBd8fD63184577525326123B519429bDc
# PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3

# ERC-8004 IdentityRegistry on Base (verify before relying on this).
# Required by RegisterAgent.s.sol — no canonical default for Base yet.
# IDENTITY_REGISTRY=0x...
